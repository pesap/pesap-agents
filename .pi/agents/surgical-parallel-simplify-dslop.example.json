{
  "chain": [
    {
      "agent": "surgical-dev",
      "task": "Orchestrate task: {task}. Define minimal safe plan + acceptance criteria."
    },
    {
      "parallel": [
        {
          "agent": "performance-freak",
          "task": "Apply performance-focused improvements based on:\n\n{previous}"
        },
        {
          "agent": "code-reviewer",
          "task": "Review for bug/security risks in:\n\n{previous}"
        }
      ]
    },
    {
      "agent": "simplify",
      "task": "Simplify and de-duplicate based on:\n\n{previous}"
    },
    {
      "agent": "dslop",
      "task": "Run final deslop pass and apply only high-signal fixes."
    }
  ],
  "clarify": false
}
